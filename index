<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KidneyCare - ประเมินอาการ</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script charset="utf-8" src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Kanit', sans-serif; background-color: #f4f7f6; }
    </style>
</head>
<body class="p-4">
    <div id="mainApp" class="max-w-md mx-auto bg-white rounded-2xl shadow-lg p-6 mt-4">
        <h1 class="text-2xl font-bold text-center text-cyan-700 mb-6">ประเมินอาการประจำวัน</h1>
        
        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">ชื่อผู้ป่วย</label>
            <input type="text" id="userName" class="w-full border-2 border-gray-100 p-3 rounded-xl bg-gray-50" readonly>
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">วันนี้ท่านมีอาการอย่างไร?</label>
            <select id="symptom" onchange="updateAdvice()" class="w-full border-2 border-cyan-100 p-3 rounded-xl focus:border-cyan-500 outline-none">
                <option value="ปกติ">ปกติ ไม่บวม</option>
                <option value="บวมหน้าหรือเท้า">บวมหน้าหรือเท้า</option>
                <option value="ปัสสาวะน้อยลง">ปัสสาวะน้อยลง</option>
                <option value="หอบเหนื่อย">หอบเหนื่อย/นอนราบไม่ได้</option>
            </select>
        </div>

        <div id="adviceBox" class="p-4 rounded-xl mb-6 bg-green-50 border border-green-200">
            <p class="font-bold text-green-800">💡 คำแนะนำ:</p>
            <p id="adviceText" class="text-green-700">ดูแลตัวเองตามปกติ จำกัดการกินเค็ม</p>
        </div>

        <button id="btnSubmit" onclick="saveData()" class="w-full bg-cyan-600 text-white py-4 rounded-xl font-bold text-lg shadow-lg active:scale-95 transition-all">
            💾 บันทึกและแจ้งเตือนเข้า LINE
        </button>
    </div>

    <script>
        const MY_LIFF_ID = "2009546368-mX5qNfbN"; // ใส่ LIFF ID ของคุณ
        let userId = "";

        async function initApp() {
            try {
                await liff.init({ liffId: MY_LIFF_ID });
                if (!liff.isLoggedIn()) {
                    liff.login();
                } else {
                    const profile = await liff.getProfile();
                    userId = profile.userId;
                    document.getElementById('userName').value = profile.displayName;
                }
            } catch (err) {
                console.error("LIFF Error:", err);
            }
        }
        window.onload = initApp;

        function updateAdvice() {
            const symptom = document.getElementById('symptom').value;
            const adviceBox = document.getElementById('adviceBox');
            const adviceText = document.getElementById('adviceText');

            if(symptom === 'ปกติ') {
                adviceText.innerText = "ดูแลตัวเองตามปกติ จำกัดการกินเค็ม";
                adviceBox.className = "p-4 rounded-xl mb-6 bg-green-50 border border-green-200";
            } else if(symptom === 'หอบเหนื่อย') {
                adviceText.innerText = "อาการอันตราย! กรุณาโทรแจ้งหน่วยฉุกเฉินหรือมาโรงพยาบาลทันที";
                adviceBox.className = "p-4 rounded-xl mb-6 bg-red-50 border border-red-200";
            } else {
                adviceText.innerText = "ควรงดดื่มน้ำมากเกินไป และลดเค็มเคร่งครัด หากไม่ดีขึ้นใน 24 ชม. ให้มาพบแพทย์";
                adviceBox.className = "p-4 rounded-xl mb-6 bg-yellow-50 border border-yellow-200";
            }
        }

        async function saveData() {
            const btn = document.getElementById('btnSubmit');
            btn.disabled = true;
            btn.innerText = "⏳ กำลังบันทึก...";

            const data = {
                userId: userId,
                userName: document.getElementById('userName').value,
                symptom: document.getElementById('symptom').value,
                advice: document.getElementById('adviceText').innerText
            };

            try {
                // ส่งข้อมูลไปที่ doPost ของ Apps Script
                const response = await fetch(window.location.href.replace(/\/exec.*$/, "/exec"), {
                    method: 'POST',
                    body: JSON.stringify(data)
                });

                alert("บันทึกและส่งแจ้งเตือนเรียบร้อยแล้ว!");
                liff.closeWindow();
            } catch (error) {
                alert("เกิดข้อผิดพลาดในการเชื่อมต่อ");
                btn.disabled = false;
                btn.innerText = "💾 บันทึกและแจ้งเตือนเข้า LINE";
            }
        }
    </script>
</body>
</html>
